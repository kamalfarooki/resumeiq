# Copy this file to .env and fill in a real value before deploying.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-value

# Optional — defaults to 5000 locally; most hosts set this for you.
PORT=5000

# Optional — leave unset for local development (falls back to in-memory
# sessions, fine for a single process). Set this in production once you
# run more than one worker. See README.md "Setting up Redis".
# REDIS_URL=redis://red-xxxxx:6379
